# Use fixture mode for deterministic demos without model API calls.
DEMO_MODE=fixture

# Required for live MiniMax calls when DEMO_MODE=live.
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/anthropic

# Shared secret for company registration demo endpoint.
REGISTRY_ADMIN_SECRET=dev-admin-secret

# Set to 0 to disable POST /api/demo/reset.
ALLOW_DEMO_RESET=1

# Bind address/port for FastAPI server.
# Use APP_HOST=0.0.0.0 to expose on LAN or from a VM/container.
APP_HOST=127.0.0.1
APP_PORT=5050
